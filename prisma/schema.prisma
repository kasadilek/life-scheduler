generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   // hex color for UI
  icon      String   // emoji icon
  createdAt DateTime @default(now())

  timeEntries TimeEntry[]
  goals       Goal[]
}

model TimeEntry {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  startedAt  DateTime @default(now())
  stoppedAt  DateTime?
  duration   Int?     // duration in seconds, computed on stop
  note       String?
  createdAt  DateTime @default(now())
}

model Goal {
  id           String   @id @default(cuid())
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  targetHours  Float    // target hours per period
  period       String   // "daily" | "weekly" | "monthly"
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LifeGoal {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("drafting") // drafting | planned | active | completed
  targetDate  DateTime?
  planSummary String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  chatMessages ChatMessage[]
  milestones   Milestone[]
}

model ChatMessage {
  id         String   @id @default(cuid())
  lifeGoalId String
  lifeGoal   LifeGoal @relation(fields: [lifeGoalId], references: [id], onDelete: Cascade)
  role       String   // "user" | "assistant"
  content    String
  createdAt  DateTime @default(now())
}

model Milestone {
  id          String    @id @default(cuid())
  lifeGoalId  String
  lifeGoal    LifeGoal  @relation(fields: [lifeGoalId], references: [id], onDelete: Cascade)
  title       String
  description String?
  orderIndex  Int
  targetDate  DateTime?
  status      String    @default("pending") // pending | in_progress | completed
  createdAt   DateTime  @default(now())

  tasks Task[]
}

model Task {
  id            String    @id @default(cuid())
  milestoneId   String
  milestone     Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  frequency     String?   // "daily" | "weekly" | "once"
  scheduledDate DateTime? // specific date this task is scheduled for
  estimatedMins Int?
  startHour     Int?      // hour of day (0-23) for calendar event
  learningObjectives String? // JSON: ["objective 1", "objective 2", ...]
  resources          String? // JSON: [{"title":"...","url":"...","type":"...","durationMins":15}]
  orderIndex    Int
  status        String    @default("pending") // pending | completed
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
}
